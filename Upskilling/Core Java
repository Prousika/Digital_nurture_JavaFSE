USING PREPARED STATEMENT

import java.sql.*;
public class Demo {
   public static void main(String[] args)throws Exception {
       String url = "jdbc:mysql://localhost:3306/jdbcjava";
       String username = "root";
       String password = "root1234";
       Connection con = DriverManager.getConnection(url, username, password);
       // insert
       String sql = "insert into student values(?,?,?)";
       PreparedStatement st = con.prepareStatement(sql);
       st.setInt(1,10);
       st.setString(2,"surya");
       st.setString(3,"eee");
       st.executeUpdate();

       //update
       String up = "update student set department = ? where rollNo = ?";
       PreparedStatement ps = con.prepareStatement(up);
       ps.setString(1, "aiml");
       ps.setInt(2,3);
       ps.executeUpdate();

        //select-p
       String sql1 = "select * from student where rollNo = ?";
       PreparedStatement st1 = con.prepareStatement(sql1);
       st1.setInt(1,3);
       ResultSet rs = st1.executeQuery();
       while(rs.next()){
           System.out.println(rs.getInt(1)+" "+rs.getString(2)+" "+rs.getString(3));
       }
       con.close();
   }
}


TRANSACTION HANDLING IN JAVA

import java.sql.*;
public class demo3 {
    public static void main(String[] args)throws Exception {
        String url = "jdbc:mysql://localhost:3306/accounts";
        String username = "root";
        String password = "root1234";

        Connection con =
                DriverManager.getConnection(url, username, password);
        PreparedStatement sys = con.prepareStatement("Select * from account");
        ResultSet rs = sys.executeQuery();
        while(rs.next()){
            System.out.println(rs.getInt(1)+" "+rs.getString(2)+" "+rs.getInt(3));
        }
        try {
            con.setAutoCommit(false);
            String debit="update account set balance = balance-? where accNo=?";
            PreparedStatement ps = con.prepareStatement(debit);
            int bal=1000;
            ps.setInt(1,bal);
            ps.setInt(2,101);
            ps.executeUpdate();


            String credit="update account set balance = balance+? where accNo=?";
            PreparedStatement ps1 = con.prepareStatement(credit);
            ps1.setInt(1,bal);
            ps1.setInt(2,102);
            ps1.executeUpdate();

            con.commit();
            System.out.println("Transaction Successfull");

        }
        catch(Exception e){
            con.rollback();
            System.out.println("Transaction Failed");
        }
        PreparedStatement sys1 = con.prepareStatement("Select * from account");
        ResultSet rs1 = sys1.executeQuery();
        while(rs1.next()){
            System.out.println(rs1.getInt(1)+" "+rs1.getString(2)+" "+rs1.getInt(3));
        }
        con.close();
    }
}

