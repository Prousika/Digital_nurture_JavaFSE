PARALLEL STREAM

import java.util.*;
public class parallelStreamdemo {
    public static void main(String[] args){
        int size =10_000;
        List<Integer> list = new ArrayList<>(size);
        Random ran = new Random();
        for(int i=0;i<=size;i++){
            list.add(ran.nextInt(100));
        }
        long start = System.currentTimeMillis();
        long sum1 =list.stream().map(n->n*2).reduce(0, (a,b)-> a+b);
        long end = System.currentTimeMillis();

        long s = System.currentTimeMillis();
        long sum2 = list.parallelStream().map(n->n*2).mapToInt(i->i).sum();
        long e = System.currentTimeMillis();

        System.out.println("stream: " + (end - start));
        System.out.println("parallel stream: " + (e - s));
        }
}


